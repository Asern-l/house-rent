JWT_SECRET=change_me_to_a_long_random_string
PORT=3000
HOST=127.0.0.1
AUTH_PORT=3005
CHAIN_ENV=sepolia
JSON_BODY_LIMIT=100mb

# Optional overrides:
# SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# LOCAL_RPC_URL=http://127.0.0.1:8545

# Note:
# When using scripts/start-sepolia-services.ps1 or scripts/start-local-services.ps1,
# do not manually change CHAIN_ENV here. The script injects it for the process.
